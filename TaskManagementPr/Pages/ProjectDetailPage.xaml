<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pageModels="clr-namespace:TaskManagementPr.PageModels"
             xmlns:models="clr-namespace:TaskManagementPr.Models"
             xmlns:pages="clr-namespace:TaskManagementPr.Pages"
             xmlns:sf="clr-namespace:Syncfusion.Maui.Toolkit.TextInputLayout;assembly=Syncfusion.Maui.Toolkit"
             xmlns:controls="clr-namespace:TaskManagementPr.Pages.Controls"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:fonts="clr-namespace:Fonts"
             x:Class="TaskManagementPr.Pages.ProjectDetailPage"
             x:Name="ProjectRoot"
             x:DataType="pageModels:ProjectDetailPageModel"
             Title="Проект">

    <ContentPage.Resources>
        <ResourceDictionary>
            <toolkit:InvertedBoolConverter x:Key="InvertedBoolConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ContentPage.ToolbarItems>
        <ToolbarItem
            Text="Удалить"
            Command="{Binding DeleteCommand}"
            Order="Primary"
            Priority="0"
            IconImageSource="{StaticResource IconDelete}"
            SemanticProperties.Description="Удалить проект" />
    </ContentPage.ToolbarItems>

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="{StaticResource LayoutPadding}" Spacing="{StaticResource LayoutSpacing}">
                <sf:SfTextInputLayout 
                    Hint="Название проекта" >
                    <Entry
                        Text="{Binding Name}"
                        IsEnabled="{Binding CanEditProject}"
                        SemanticProperties.Description="Название проекта" />
                </sf:SfTextInputLayout>

                <sf:SfTextInputLayout 
                    Hint="Описание">
                    <Entry
                        Text="{Binding Description}"
                        IsEnabled="{Binding CanEditProject}"
                        SemanticProperties.Description="Описание проекта" />
                </sf:SfTextInputLayout>

               <sf:SfTextInputLayout
                    Hint="Категория"
                    SemanticProperties.Description="Выбор категории проекта"
                    SemanticProperties.Hint="Список категорий">
                    <Picker SemanticProperties.Hint="Выберите категорию проекта"
                            ItemsSource="{Binding Categories}"
                            SelectedItem="{Binding Category}"
                            SelectedIndex="{Binding CategoryIndex}"
                            IsEnabled="{Binding CanEditProject}"
                            SemanticProperties.Description="Категория проекта"/>
                </sf:SfTextInputLayout>

                <Label 
                    Text="Иконка" 
                    Style="{StaticResource Title2}"/>
                <Label Text="Редактировать проект может только владелец."
                       FontSize="13"
                       LineBreakMode="WordWrap"
                       TextColor="{AppThemeBinding Light=#555555,Dark=#bbbbbb}"
                       IsVisible="{Binding CanEditProject, Converter={StaticResource InvertedBoolConverter}}" />
                <CollectionView 
                    HeightRequest="44" Margin="0,0,0,15"
                    IsEnabled="{Binding CanEditProject}"
                    SelectionMode="Single" 
                    SelectedItem="{Binding Icon}"
                    SelectionChangedCommand="{Binding IconSelectedCommand}"
                    SelectionChangedCommandParameter="{Binding Icon}"
                    ItemsSource="{Binding Icons}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:IconData">
                            <Grid RowDefinitions="Auto,4" RowSpacing="{StaticResource size60}"
                                 SemanticProperties.Description="{Binding Description}">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal">
                                            <VisualState.Setters>
                                                <Setter Property="BackgroundColor" Value="Transparent"/>
                                                <Setter TargetName="SelectedIndicator" Property="BoxView.IsVisible" Value="False"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Selected">
                                            <VisualState.Setters>
                                                <Setter Property="BackgroundColor" Value="Transparent"/>
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter TargetName="SelectedIndicator" Property="BoxView.IsVisible" Value="True"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                
                                <Label 
                                    Text="{Binding Icon}"
                                    x:Name="IconImage"
                                    FontFamily="{x:Static fonts:FluentUI.FontFamily}" 
                                    FontSize="24" 
                                    VerticalOptions="Center"
                                    HorizontalOptions="Center"
                                    TextColor="{AppThemeBinding Light={StaticResource DarkOnLightBackground},Dark={StaticResource LightOnDarkBackground}}"/>
                                <BoxView x:Name="SelectedIndicator" Color="{StaticResource Primary}" HeightRequest="4" HorizontalOptions="Fill" Grid.Row="1"/>
                            </Grid>                            
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="{StaticResource LayoutSpacing}"/>
                    </CollectionView.ItemsLayout>
                </CollectionView>
                <Button Text="Сохранить проект"
                    MinimumHeightRequest="{OnIdiom 44, Desktop=60}"
                    Command="{Binding SaveCommand}"
                    IsEnabled="{Binding CanEditProject}" />

                <Label Text="Участники проекта" Style="{StaticResource Title2}" />
                <CollectionView ItemsSource="{Binding Members}" MaximumHeightRequest="280">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:ProjectMember">
                            <Grid Padding="0,8" ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0"
                                       Text="{Binding DisplayLabel}"
                                       VerticalOptions="Center" />
                                <Button Grid.Column="1"
                                        Text="Удалить"
                                        Command="{Binding BindingContext.RemoveMemberCommand, Source={x:Reference ProjectRoot}, x:DataType=ContentPage}"
                                        CommandParameter="{Binding .}"
                                        IsVisible="{Binding BindingContext.IsCurrentUserOwner, Source={x:Reference ProjectRoot}, x:DataType=ContentPage}" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Label Text="Приглашение: введите email. Если это ваш email — доступ сразу; если чужой — он увидит проект после входа под этим email."
                       FontSize="13" LineBreakMode="WordWrap"
                       TextColor="{AppThemeBinding Light=#555555,Dark=#bbbbbb}"
                       IsVisible="{Binding CanManageMembers}" />
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10" IsVisible="{Binding CanManageMembers}">
                    <Button Grid.Column="0" Text="Пригласить" Command="{Binding InviteMemberCommand}" />
                    <Button Grid.Column="1" Text="Передать права владельца" Command="{Binding TransferOwnershipCommand}" />
                </Grid>

                <Button Text="Покинуть проект"
                        Command="{Binding LeaveProjectCommand}"
                        IsVisible="{Binding HasPersistedProject}" />

                <Grid HeightRequest="44">
                    <Label 
                        Text="Задачи" 
                        Style="{StaticResource Title2}" 
                        VerticalOptions="Center"/>
                    <ImageButton 
                        Source="{StaticResource IconClean}"
                        HorizontalOptions="End"
                        VerticalOptions="Center"
                        Aspect="Center"
                        HeightRequest="44"
                        WidthRequest="44"
                        IsVisible="{Binding HasCompletedTasks}"
                        Command="{Binding CleanTasksCommand}"
                        SemanticProperties.Description="Clean up"
                        />
                </Grid>
                <VerticalStackLayout 
                    Spacing="{StaticResource LayoutSpacing}"
                    BindableLayout.ItemsSource="{Binding Tasks}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <controls:TaskView TaskCompletedCommand="{Binding TaskCompletedCommand, Source={RelativeSource AncestorType={x:Type pageModels:ProjectDetailPageModel}}, x:DataType=pageModels:ProjectDetailPageModel}" />
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <controls:AddButton Command="{Binding AddTaskCommand}"
                            IsVisible="{Binding IsCurrentUserOwner}"
                            SemanticProperties.Description="Добавить задачу"
                            ToolTipProperties.Text="Добавить задачу" />
    </Grid>
    
</ContentPage>